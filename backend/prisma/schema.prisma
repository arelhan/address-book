// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Contact {
  id          String   @id @default(cuid())
  type        String   // PERSON | COMPANY
  name        String   // Kişi adı-soyadı veya firma ünvanı
  title       String?  // Ünvan (Müdür, Direktör vb.)
  department  String?  // Birim / Departman
  email       String?
  address     String?
  notes       String?
  avatarUrl   String?
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // İlişkiler
  phones      Phone[]
  parentId    String?
  parent      Contact?   @relation("SubUnits", fields: [parentId], references: [id])
  children    Contact[]  @relation("SubUnits")

  @@index([type])
  @@index([name])
  @@index([deletedAt])
}

model User {
  id                 String   @id @default(cuid())
  fullName           String
  username           String   @unique
  email              String   @unique
  nationalId         String   @unique
  phone              String
  role               String   @default("VIEWER")
  passwordSalt       String
  passwordHash       String
  resetTokenHash     String?
  resetTokenExpiresAt DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  logs               AuditLog[]

  @@index([role])
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  entityType String
  entityId   String?
  details    String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([action])
  @@index([userId])
}

model Phone {
  id        String @id @default(cuid())
  number    String
  label     String @default("Cep") // Cep, İş, Ev, Faks vb.
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
}
